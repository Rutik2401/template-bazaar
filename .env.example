# Copy to `.env.local` for local dev, and set the same key in Vercel → Project →
# Settings → Environment Variables for production.

# Your canonical production origin (no trailing slash). Drives canonical URLs,
# Open Graph tags, the XML sitemap and robots.txt. Without it, deployments fall
# back to the Vercel deployment host (VERCEL_URL), which is fine for previews but
# NOT what you want as the indexed canonical for production.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Authentication (NextAuth / Auth.js v5) ──────────────────────────────────
# Login is OPTIONAL infrastructure: the whole free funnel (browse, preview,
# download free templates) works without any of these. They are only needed to
# let users sign in and unlock PREMIUM downloads without a watermark.
# If unset, the app still builds and runs — premium downloads simply stay
# watermarked and the "Sign in" button has nothing to connect to.

# A long random secret used to sign session JWTs. Generate one with:
#   npx auth secret      (or: openssl rand -base64 33)
AUTH_SECRET=

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials
# → OAuth client ID → "Web application"). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google   (local)
#   https://your-domain.com/api/auth/callback/google  (production)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email OTP (passwordless) — not active yet. Turning it on needs an email sender
# (e.g. RESEND_API_KEY) plus a short-lived code store (e.g. Upstash Redis). See
# the scaffold in src/auth.config.js.
# RESEND_API_KEY=
